# คัดลอกเป็น .env แล้วเติมค่า (ตอน deploy บน cloud ให้ตั้งเป็น Environment Variables แทน)

# จาก OAuth client แบบ "Web application" ใน Google Cloud Console
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx

# URL ของเว็บ (ตอน dev ใช้ localhost, ตอน deploy ใช้ URL จริงของ host)
BASE_URL=http://localhost:5000

# กุญแจลับของ session — สุ่มมาสักชุด (เช่น `python -c "import secrets;print(secrets.token_hex(32))"`)
FLASK_SECRET=change-this-to-a-random-string

# อัปเดตทุกกี่นาที
UPDATE_INTERVAL_MINUTES=30

# ตอน dev บน http localhost ต้องเปิดบรรทัดนี้ (ตอน deploy https ให้ลบ/comment ทิ้ง)
OAUTHLIB_INSECURE_TRANSPORT=1
